# ── Broker Selection ─────────────────────────────────────────
# Options: "alpaca" | "schwab" | "fidelity"
BROKER=alpaca

# ── Alpaca ────────────────────────────────────────────────────
# Get keys at: https://app.alpaca.markets → API Keys
# Mode: "paper" = no real money | "live" = real trading
ALPACA_MODE=paper
ALPACA_API_KEY=your_alpaca_key_here
ALPACA_API_SECRET=your_alpaca_secret_here

# ── Schwab (future) ───────────────────────────────────────────
# SCHWAB_API_KEY=
# SCHWAB_API_SECRET=

# ── Fidelity (future) ─────────────────────────────────────────
# FIDELITY_API_KEY=
# FIDELITY_API_SECRET=
